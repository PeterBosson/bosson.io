<style>
  .game-fab {
    position: fixed;
    bottom: 2rem;
    left: 2rem;
    width: 56px;
    height: 56px;
    background-color: var(--card-background); /* Matches your white card */
    color: var(--text-primary); /* Matches your dark text/background */
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 12px var(--shadow-color-dark);
    transition: transform 0.2s ease, background-color 0.2s ease;
    z-index: 1000;
    text-decoration: none;
  }

  .game-fab:hover {
    transform: scale(1.1);
  }
</style>