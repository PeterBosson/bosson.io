{
  "rewrites": [
    {
      "source": "/csmoreless",
      "destination": "https://cs-more-less.vercel.app/"
    },
    {
      "source": "/csmoreless/(.*)",
      "destination": "https://cs-more-less.vercel.app/$1"
    },
    {
      "source": "/api/(.*)",
      "destination": "https://cs-more-less.vercel.app/api/$1"
    }
  ]
}
